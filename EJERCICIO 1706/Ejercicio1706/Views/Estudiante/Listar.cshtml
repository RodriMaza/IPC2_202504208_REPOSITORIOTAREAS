@model IEnumerable<Ejercicio1706.Models.Estudiante>

@{
    ViewData["Title"] = "Lista de Estudiantes";
}

<div class="text-center mb-4">
    <h1 class="display-4">Lista de Estudiantes</h1>
</div>

<div class="container">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Carné</th>
                <th>Nombre</th>
                <th>Promedio</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Carne</td>
                    <td>@item.Nombre</td>
                    <td>@item.Promedio</td>
                </tr>
            }
        </tbody>
    </table>
</div>
